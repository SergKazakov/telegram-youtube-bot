{
  "private": true,
  "scripts": {
    "prestart": "npm run build",
    "start": "node -r dotenv-safe/config dist",
    "dev": "ts-node-dev -T --notify=false -r dotenv-safe/config src",
    "test": "eslint --ignore-path .gitignore --fix --ext ts .",
    "build": "tsc"
  },
  "eslintConfig": {
    "root": true,
    "extends": [
      "plugin:import/recommended",
      "plugin:import/typescript",
      "xo/esnext",
      "plugin:unicorn/recommended",
      "plugin:@typescript-eslint/recommended",
      "plugin:prettier/recommended",
      "prettier/@typescript-eslint"
    ],
    "rules": {
      "unicorn/filename-case": [
        "error",
        {
          "case": "camelCase"
        }
      ],
      "unicorn/prevent-abbreviations": "off",
      "unicorn/no-fn-reference-in-iterator": "off",
      "unicorn/no-null": "off",
      "camelcase": [
        "error",
        {
          "properties": "never"
        }
      ],
      "import/order": [
        "error",
        {
          "newlines-between": "always"
        }
      ]
    }
  },
  "eslintIgnore": [
    "dist"
  ],
  "prettier": {
    "trailingComma": "all",
    "semi": false,
    "arrowParens": "avoid"
  },
  "devDependencies": {
    "@arkweid/lefthook": "^0.7.2",
    "@tsconfig/node12": "^1.0.7",
    "@types/he": "^1.1.1",
    "@types/ioredis": "^4.17.9",
    "@types/mongoose": "^5.10.3",
    "@types/node": "^14.14.14",
    "@typescript-eslint/eslint-plugin": "^4.10.0",
    "@typescript-eslint/parser": "^4.10.0",
    "eslint": "^7.16.0",
    "eslint-config-prettier": "^7.1.0",
    "eslint-config-xo": "^0.33.1",
    "eslint-plugin-import": "^2.22.1",
    "eslint-plugin-prettier": "^3.3.0",
    "eslint-plugin-unicorn": "^24.0.0",
    "prettier": "^2.2.1",
    "ts-node-dev": "1.1.1",
    "typescript": "^4.1.3"
  },
  "dependencies": {
    "@godaddy/terminus": "^4.5.0",
    "dayjs": "^1.9.7",
    "dotenv-safe": "^8.2.0",
    "dumper.js": "^1.3.1",
    "fast-xml-parser": "^3.17.5",
    "googleapis": "^66.0.0",
    "he": "^1.2.0",
    "ioredis": "^4.19.4",
    "mongoose": "^5.11.8",
    "pubsubhubbub": "^1.0.1",
    "telegraf": "^3.38.0"
  },
  "engines": {
    "node": "12"
  }
}
